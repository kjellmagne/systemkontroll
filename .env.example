# Docker Compose deployment settings
SYSTEMKONTROLL_IMAGE=ghcr.io/kjellmagne/systemkontroll:latest
SYSTEMKONTROLL_HOST_PORT=3100
SYSTEMKONTROLL_DB_PASSWORD=change-me

# Runtime settings used inside the app container
PORT=3000
ORG_STRUCTURE_PATH=/data/organization-structure.json
DATABASE_SSL=false

# Option A: use one PostgreSQL connection string
# DATABASE_URL=postgresql://systemkontroll:systemkontroll@127.0.0.1:5432/systemkontroll

# Option B: use individual PostgreSQL settings
DB_HOST=db
DB_PORT=5432
DB_NAME=systemkontroll
DB_USER=systemkontroll
DB_PASSWORD=change-me

# Login is optional for local development. Set AUTH_REQUIRED=true in production.
AUTH_REQUIRED=false
AUTH_BASE_URL=http://192.168.222.171:3100
AUTH_SESSION_SECRET=replace-with-at-least-32-random-characters
AUTH_SESSION_HOURS=12
AUTH_COOKIE_SECURE=false

# Optional external-provider allow-list. Users must also exist in SystemKontroll.
AUTH_ALLOWED_EMAIL_DOMAINS=
AUTH_ALLOWED_EMAILS=

# Built-in SystemKontroll login. These values bootstrap the first admin user.
AUTH_LOCAL_ENABLED=true
AUTH_LOCAL_USERNAME=admin
AUTH_LOCAL_EMAIL=admin@example.no
AUTH_LOCAL_NAME=SystemKontroll administrator
AUTH_LOCAL_PASSWORD=change-me
# Alternative to AUTH_LOCAL_PASSWORD:
# AUTH_LOCAL_PASSWORD_SHA256=

# Microsoft Entra ID / Azure AD login
AUTH_MICROSOFT_TENANT_ID=
AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=

# Google login
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
